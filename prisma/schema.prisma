generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  passwordHash  String?
  image         String?
  role          String         @default("customer")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  subscriptions Subscription[]
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  products Product[]
}

model Product {
  id           String      @id @default(cuid())
  name         String
  slug         String      @unique
  description  String
  categoryId   String
  category     Category    @relation(fields: [categoryId], references: [id])
  price        Int
  inventory    Int
  images       String[]
  benefits     String[]
  nutrition    String[]
  usage        String[]
  rating       Float       @default(0)
  reviewsCount Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  orderItems   OrderItem[]
  reviews      Review[]
}

model Inventory {
  id       String   @id @default(cuid())
  sku      String   @unique
  quantity Int
  lowStock Int
  updatedAt DateTime @updatedAt
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  fullName  String
  phone     String
  address   String
  city      String
  state     String
  pincode   String
  country   String  @default("India")
  isDefault Boolean @default(false)
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  orderNumber   String      @unique
  status        String      @default("pending")
  subtotal      Int
  shipping      Int
  tax           Int
  total         Int
  paymentMethod String
  paymentStatus String      @default("pending")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
  payments      Payment[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Int
}

model Payment {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  provider   String
  providerId String?
  amount     Int
  currency   String   @default("INR")
  status     String   @default("pending")
  createdAt  DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int
  comment   String
  createdAt DateTime @default(now())
}

model Coupon {
  id        String    @id @default(cuid())
  code      String    @unique
  discount  Int
  isActive  Boolean   @default(true)
  expiresAt DateTime?
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  plan      String
  price     Int
  status    String   @default("active")
  frequency String   @default("monthly")
  createdAt DateTime @default(now())
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  excerpt   String
  category  String
  image     String
  published Boolean  @default(true)
  createdAt DateTime @default(now())
}
